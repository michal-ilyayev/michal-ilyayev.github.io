---
import Layout from '~/layouts/Layout.astro';
import { getImage } from 'astro:assets';
import { type GalleryImage } from '~/components/gallery/types';
import Gallery from '~/components/gallery/Gallery.tsx';
import ComingSoon from '~/components/ComingSoon.astro';
import { artImages, type ArtImage } from '~/data/art-gallery';
import { THUMB_SIZE } from '~/components/gallery/consts';
import type { ImageMetadata } from 'astro';

const imgFiles = import.meta.glob<{ default: ImageMetadata }>('/src/assets/art/**/*.{jpeg,jpg,png}');

const optimiseImage = async (path: string) => {
  const img: ImageMetadata = (await imgFiles[`/src/assets/art/${path}`]()).default;
  const optimized = await getImage({ src: img, format: 'webp', inferSize: true });
  const thumbnail = await getImage({
    src: img, format: 'webp', quality: 50,
    width: THUMB_SIZE, height: THUMB_SIZE * (img.height / img.width),
  });
  return { src: optimized.src, srcThumb: thumbnail.src, width: img.width, height: img.height };
};

const loadGalleryImage = async (imageData: ArtImage): Promise<GalleryImage | undefined> => {
  try {
    const [primary, ...extras] = imageData.paths;
    const primaryData = await optimiseImage(primary);
    const extraSrcs   = await Promise.all(extras.map((p) => optimiseImage(p)));
    return {
      src: primaryData.src, srcThumb: primaryData.srcThumb,
      width: primaryData.width, height: primaryData.height,
      title: imageData.title, description: imageData.description,
      medium: imageData.medium, year: imageData.year,
      allSrcs: [primaryData, ...extraSrcs],
    } as GalleryImage;
  } catch (e) { console.error(e); return undefined; }
};

const images = (
  await Promise.all(artImages.map(loadGalleryImage))
).filter((img): img is GalleryImage => img !== undefined);
---

<Layout title="Visual Arts Portfolio">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Playfair+Display:ital,wght@0,500;0,700;1,400&display=swap" rel="stylesheet" />

  <div class="bg1"><div></div></div>
  <div>
    <div class="va-hero">
      <div class="va-hero__inner">
        <h1 class="va-hero__title">
          <span class="va-hero__my">My</span>
          <span class="va-hero__visual">VISUAL ARTS</span>
          <span class="va-hero__portfolio">Portfolio</span>
        </h1>

        <p class="va-hero__sub">
          Below are some of my favorite artworks that I've developed <br class="hidden-sm" />
          during high school, each representing a unique aspect of my artistic growth.
        </p>

        <!-- three-stroke SVG brushstroke separator -->
        <div class="va-hero__sep">
          <svg viewBox="0 0 500 32" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="sg" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%"   stop-color="#7065f9" stop-opacity="0" />
                <stop offset="15%"  stop-color="#7065f9" />
                <stop offset="50%"  stop-color="#a879ff" />
                <stop offset="85%"  stop-color="#f06ab7" />
                <stop offset="100%" stop-color="#f06ab7" stop-opacity="0" />
              </linearGradient>
            </defs>
            <path d="M10 16 C55 8,100 22,150 14 C200 6,250 20,300 13 C350 6,400 19,450 14 C470 11,486 16,495 15" fill="none" stroke="url(#sg)" stroke-width="8" stroke-linecap="round" opacity=".85"/>
            <path d="M15 11 C60 5,105 17,155 10 C205 3,255 16,305 9 C355 2,405 15,455 10 C472 8,488 12,496 11" fill="none" stroke="url(#sg)" stroke-width="3" stroke-linecap="round" opacity=".4"/>
            <path d="M20 20 C70 14,120 25,170 18 C220 11,270 23,320 17 C370 11,415 22,460 17 C475 15,488 19,496 18" fill="none" stroke="url(#sg)" stroke-width="2" stroke-linecap="round" opacity=".25"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="page-container mt-6 mb-12 min-h-dvh">
      {!images || images.length === 0 ? (
        <ComingSoon />
      ) : (
        <Gallery images={images as GalleryImage[]} client:only="react" />
      )}
    </div>
  </div>
</Layout>


<style lang="scss">

// "my" hight
  .va-hero {
    position: relative;
    padding: 3rem 1.5rem 1rem;
    text-align: center;
    overflow: hidden;
  }

  // pink right blob 
  .va-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 50% 35%, rgba(240, 106, 183, 0.12), transparent 65%),
      radial-gradient(ellipse 80% 60% at 50% 25%, rgba(112, 101, 249, 0.12), transparent 70%);
    pointer-events: none;
  }

  // the whole header 
  .va-hero__title {
    margin: 0;
    line-height: 0.99;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .va-hero__my {
    font-family: Georgia, serif;
    font-size: clamp(2.2rem, 5vw, 4.2rem);
    font-style: italic;
    font-weight: 300;
    color:#273449;
    transform: rotate(-2deg);
    margin-bottom: 0.3rem;
    opacity: 0.85;
  }

  // "VISUAL ARTS" — Permanent Marker brushstroke font
  // ↓ TO MAKE BIGGER: increase the last value in clamp (currently 11rem)
  // ↓ TO MAKE SMALLER: decrease it
  .va-hero__visual {
    font-family: 'Permanent Marker', cursive;
    font-size: clamp(4rem, 12vw, 9rem); // clamp(min, fluid, MAX ← change this)
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 0.95;
    white-space: nowrap; // keeps it on one line on desktop — removed on mobile below
    background: linear-gradient(120deg, #7065f9 0%, #a879ff 45%, #f06ab7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .va-hero__portfolio {
    font-family: Georgia, serif;
    font-size: clamp(3rem, 7vw, 8rem);
    font-style: italic;
    font-weight: 300;
    color: #273449;
    margin-top: 0.99rem;
  }

  .va-hero__sub {
    font-size: clamp(0.95rem, 1.2vw, 1.15rem);
    line-height: 1.75;
    color: #4f4c57;
    max-width: 56ch;
    margin: 1.9rem auto 0;
  }

  // SVG wavy separator
  // ↓ TO MAKE WIDER: increase the last value in clamp (currently 820px)
  // ↓ TO MAKE TALLER/THICKER: edit stroke-width values in the SVG above
  .va-hero__sep {
    width: clamp(300px, 85vw, 820px); // clamp(min, fluid, MAX ← change this)
    margin: 2rem auto 0;

    svg { width: 100%; height: auto; display: block; }
  }

  @media (max-width: 700px) {
    .va-hero { padding: 4rem 1rem 3rem; }

    // on mobile: allow VISUAL ARTS to wrap to two lines (VISUAL / ARTS)
    .va-hero__visual {
      white-space: normal;
      font-size: clamp(3.8rem, 18vw, 6rem); // ← adjust mobile size here
      word-break: break-word;
      hyphens: none;
    }

    .va-hero__portfolio { font-size: clamp(2.4rem, 12vw, 4rem); }
    .va-hero__sep { width: 90vw; }
  }
</style>