---
import Layout from '~/layouts/Layout.astro';
import { getImage } from 'astro:assets';
import { type GalleryImage } from '~/components/gallery/types';
import Gallery from '~/components/gallery/Gallery.tsx';
import ComingSoon from '~/components/ComingSoon.astro';
import { artImages, type ArtImage } from '~/data/art-gallery';
import { THUMB_SIZE } from '~/components/gallery/consts';
import type { ImageMetadata } from 'astro';

const imgFiles = import.meta.glob<{ default: ImageMetadata }>('/src/assets/art/**/*.{jpeg,jpg,png}');

// Optimise a single image path and return src + dimensions
const optimiseImage = async (path: string) => {
  const img: ImageMetadata = (await imgFiles[`/src/assets/art/${path}`]()).default;

  const optimized = await getImage({
    src: img,
    format: 'webp',
    inferSize: true,
  });

  const thumbnail = await getImage({
    src: img,
    format: 'webp',
    quality: 50,
    width: THUMB_SIZE,
    height: THUMB_SIZE * (img.height / img.width),
  });

  return {
    src: optimized.src,
    srcThumb: thumbnail.src,
    width: img.width,
    height: img.height,
  };
};

// Build a GalleryImage for each artwork
// - paths[0] is always the thumbnail shown in the grid
// - all paths are optimised and stored in allSrcs for the inner carousel
const loadGalleryImage = async (imageData: ArtImage): Promise<GalleryImage | undefined> => {
  try {
    const [primary, ...extras] = imageData.paths;

    const primaryData = await optimiseImage(primary);
    const extraSrcs   = await Promise.all(extras.map((p) => optimiseImage(p)));

    return {
      src:        primaryData.src,
      srcThumb:   primaryData.srcThumb,
      width:      primaryData.width,
      height:     primaryData.height,
      title:      imageData.title,
      description: imageData.description,
      medium:     imageData.medium,
      year:       imageData.year,
      // all views including primary — used for the inner carousel
      allSrcs: [primaryData, ...extraSrcs],
    } as GalleryImage;
  } catch (e) {
    console.error(e);
    return undefined;
  }
};

const images = (
  await Promise.all(artImages.map(loadGalleryImage))
).filter((img): img is GalleryImage => img !== undefined);
---

<Layout title="Visual Arts Portfolio">
  <div class="bg1"><div></div></div>
  <div>
    <div class="my-24">
      <h1 class="text-4xl text-center my-6 font-handwriting text-primary">
        My Visual Arts Portfolio
      </h1>
      <p class="text-center text-gray-600 max-w-lg mx-auto p-1">
        Below are some of my favorite artworks that I've developed during high school,
        each representing a unique aspect of my artistic growth.
      </p>
    </div>
    <div class="page-container mt-6 mb-12 min-h-dvh">
      {!images || images.length === 0 ? (
        <ComingSoon />
      ) : (
        <Gallery images={images as GalleryImage[]} client:only="react" />
      )}
    </div>
  </div>
</Layout>