---
import Layout from '~/layouts/Layout.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

import GitProjectCard from '~/components/GitProjectCard.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import balloonPopImg from '~/assets/img/projects/balloon-pop.png';
import wallGameImg from '~/assets/img/projects/wall-game.png';
import whackAMoleImg from '~/assets/img/projects/whack-a-mole.png';
import thisWebsiteImg from '~/assets/img/projects/this-website.png';
import lockInImg from '~/assets/img/projects/lock-in.png';
import programmerImg from '~/assets/img/programmer.svg';
---

<Layout title="Coding Projects">
  <div class="bg2">
    <div></div>
  </div>

  <!-- ── HERO ─────────────────────────────────────────────────────────── -->
  <div class="relative">
    <div class="page-container pt-8">
      <div class="flex flex-col-reverse lg:flex-row justify-around items-center gap-12">

        <div>
          <Image src={programmerImg} height={400} alt="Programmer" />
        </div>

        <div class="hero-text">
          <p class="hero-eyebrow">Software Development</p>
          <h1 class="hero-title">
            My <em>Coding</em><br />Portfolio
          </h1>
          <p class="hero-sub">
            Over the years, I've developed a wide range of projects, each one
            representing a unique aspect of my creativity and problem-solving skills.
          </p>
          <p class="hero-sub">
            Below are some of my favorite projects that I've worked on, each one
            showcasing my passion for software development.
          </p>
          <a href="https://github.com/michal-ilyayev" target="_blank" class="hero-gh-link">
            <Icon name="mdi:github" size={18} />
            github.com/michal-ilyayev
          </a>
        </div>

      </div>
    </div>
  </div>

  <!-- ── QUOTE ─────────────────────────────────────────────────────────── -->
  <div class="page-container mt-20 mb-4">
    <div class="relative flex flex-col justify-center items-center">
      <div class="quote-box">
        <p class="quote-text">"Talk is cheap. Show me the code."</p>
        <p class="quote-author">— Linus Torvalds</p>
      </div>
      <hr class="hidden border-t border-primary w-full absolute top-[1/2] z-0 md:block" />
    </div>
  </div>

  <!-- bouncing arrow -->
  <div class="w-full mb-2">
    <div class="mx-auto mt-8 animate-bounce w-20 h-20 flex items-center justify-center text-center rounded-full bg-white shadow-sm drop-shadow-sm border">
      <Icon name="mdi:arrow-down" size={48} class="text-primary" />
    </div>
  </div>

  <!-- ── PROJECTS PANEL ─────────────────────────────────────────────────── -->
  <div class="projects-panel">
    <div class="page-container">

      <div class="panel-header">
        <p class="panel-eyebrow">Projects</p>
        <p class="panel-count">5 total · always updating</p>
      </div>

      <!-- 01 -->
      <div class="project-section">
        <p class="project-num">01</p>
        <GitProjectCard
          title="Portfolio Website"
          gitHubLink="https://github.com/michal-ilyayev/michal-ilyayev.github.io"
        >
          <Image src={thisWebsiteImg} height={700} alt="Portfolio Website" slot="image" />
          <div>
            <h2>This Website</h2>
            <p>This website was developed using <code>Astro</code> and <code>TailwindCSS</code>.</p>
            <p>For a full list of technologies and resources I used to build this website, please visit the <a href="/credits/">credits page</a>.</p>
            <p>I built this website to learn and experiment with new technologies and design ideas. Feel free to borrow any code snippets or ideas from this website for your own projects.</p>
          </div>
        </GitProjectCard>
      </div>

      <!-- 02 -->
      <div class="project-section">
        <p class="project-num">02</p>
        <ProjectCard title="LOCK-IN" projectLink="https://www.lockin.click/">
          <Image src={lockInImg} height={700} alt="LOCK-IN" slot="image" />
          <div>
            <h2>LOCK-IN</h2>
            <p>LOCK-IN transforms how coding assignments and exams are delivered, completed, and evaluated — moving beyond traditional paper-based or form-based approaches.</p>
            <p>It provides a secure, user-friendly platform for students to complete coding assignments and exams. The platform is designed to be easy to use, with a simple and intuitive interface that allows students to focus on their work while using modern code editors and tools.</p>
            <p>
              Frontend: <code>React</code>, <code>Tailwind</code>, <code>AntDesign</code>, <code>RTK Query</code><br />
              Backend: <code>Django/Python</code>, <code>DRF</code>, <code>Postgres</code>, <code>Docker</code>, <code>AWS</code>.
            </p>
          </div>
        </ProjectCard>
      </div>

      <!-- 03 -->
      <div class="project-section">
        <p class="project-num">03</p>
        <GitProjectCard title="Whack a Mole" gitHubLink="https://github.com/michal-ilyayev/whack-a-mole">
          <Image src={whackAMoleImg} height={700} alt="Whack a Mole" slot="image" />
          <div>
            <h2>Whack a Mole</h2>
            <p>The good old Whack a Mole game developed with <code>PyGame</code> and <code>Python</code>.</p>
            <p>Click on the moles to score points and avoid clicking on the bombs. The game ends when you click on a bomb 3 times.</p>
          </div>
        </GitProjectCard>
      </div>

      <!-- 04 -->
      <div class="project-section">
        <p class="project-num">04</p>
        <GitProjectCard title="Balloon Pop" gitHubLink="https://github.com/michal-ilyayev/balloon-pop">
          <Image src={balloonPopImg} height={700} alt="Balloon Pop" slot="image" />
          <div>
            <h2>Balloon Pop</h2>
            <p>A simple Balloon Pop game developed with <code>PyGame</code> and <code>Python</code>.</p>
            <p>Pop as many balloons as possible and avoid the bomb balloon. The game ends when all balloons are popped or disappeared or when you click on the bomb balloon.</p>
          </div>
        </GitProjectCard>
      </div>

      <!-- 05 -->
      <div class="project-section">
        <p class="project-num">05</p>
        <GitProjectCard title="Wall Game" gitHubLink="https://github.com/michal-ilyayev/wall-game">
          <Image src={wallGameImg} height={650} alt="Wall Game" slot="image" />
          <div>
            <h2>Wall Game</h2>
            <p>A simple Wall Game developed with <code>PyGame</code> and <code>Python</code>.</p>
            <p>Navigate your circle using the mouse through the holes in the descending walls. Avoid the bouncing balls, as they will cause you to lose lives. Additionally, ensure your circle passes through the holes accurately. Failing to do so will drag your circle down, costing you life and changing your circle's colour and size.</p>
            <p>The game ends when you lose all your lives.</p>
          </div>
        </GitProjectCard>
      </div>

    </div>
  </div>

</Layout>


<style lang="scss">

  // ── HERO ────────────────────────────────────────────────────────────────

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 520px;
    padding-top: 2rem;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #a89ec0;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;

    &::before {
      content: '';
      display: block;
      width: 1.5rem;
      height: 1px;
      background: rgba(112, 101, 249, 0.4);
    }
  }

  .hero-title {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: #160025;
    margin: 0;

    em {
      font-family: Georgia, serif;
      font-style: italic;
      font-weight: 300;
      color: #7065f9;
    }
  }

  .hero-sub {
    font-size: 1rem;
    line-height: 1.75;
    color: #5a5560;
    margin: 0;
  }

  .hero-gh-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #7065f9;
    text-decoration: none;
    border: 1.5px solid rgba(112, 101, 249, 0.25);
    background: rgba(112, 101, 249, 0.04);
    padding: 0.5rem 1rem;
    border-radius: 0.6rem;
    width: fit-content;
    margin-top: 0.5rem;
    transition: 0.2s ease;

    &:hover {
      background: rgba(112, 101, 249, 0.1);
      border-color: rgba(112, 101, 249, 0.5);
    }
  }

  // ── QUOTE ───────────────────────────────────────────────────────────────

  .quote-box {
    width: 600px;
    max-width: 100%;
    z-index: 10;
    text-align: center;
    padding: 2rem;
    border: 1px solid rgba(112, 101, 249, 0.15);
    border-radius: 1.25rem;
    background: rgba(112, 101, 249, 0.03);
  }

  .quote-text {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 1.1rem;
    color: #7065f9;
    margin: 0 0 0.4rem;
  }

  .quote-author {
    font-size: 0.85rem;
    color: #a89ec0;
    margin: 0;
  }

  // ── PROJECTS PANEL ──────────────────────────────────────────────────────
  // tinted panel creates a clear visual chapter break after the hero

  .projects-panel {
    background: #f7f5ff;
    border-top: 2px solid transparent;
    border-image: linear-gradient(to right, transparent, #a879ff, #f06ab7, transparent) 1;
    padding: clamp(3rem, 5vw, 5rem) 0;
    margin-top: 2rem;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 0.5px solid rgba(112, 101, 249, 0.15);
  }

  .panel-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #a89ec0;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.6rem;

    &::before {
      content: '';
      display: block;
      width: 1rem;
      height: 1px;
      background: rgba(112, 101, 249, 0.4);
    }
  }

  .panel-count {
    font-size: 0.75rem;
    color: #a89ec0;
    font-family: 'Courier New', monospace;
  }

  // each project gets a numbered label above its card
  .project-section {
    position: relative;
    margin-bottom: 1rem;
  }

  .project-num {
    font-family: 'Courier New', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: #a89ec0;
    letter-spacing: 0.1em;
    margin: 0 0 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;

    // short line after the number
    &::after {
      content: '';
      display: block;
      flex: 1;
      height: 0.5px;
      background: rgba(112, 101, 249, 0.12);
    }
  }

</style>