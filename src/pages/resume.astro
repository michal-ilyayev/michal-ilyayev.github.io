---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/Layout.astro';
import AvatarImg from '~/assets/img/me/3.png';
import McMasterLogo from '~/assets/img/logos/mcmaster.png';
import WestmountLogo from '~/assets/img/logos/westmount.png';
---

<Layout title="Resume">
  <div class="print:hidden absolute inset-0 bg-violet-400 bg-[size:20px_20px] opacity-20 blur-[100px]"></div>

    <a
    href="/Michal_Ilyayev_resume.pdf"
    target="_blank"
    class="btn-print"
    title="Download Resume"
  >
    <Icon name="mdi:printer" size={30} />
  </a>

  <div class="relative max-w-full min-h-screen px-0 sm:px-4 print:px-0 py-10 print:py-5">
    <div class="w-full sm:max-w-[52rem] bg-white sm:rounded-md shadow-xl mx-auto print:w-[52rem] print:h-[100vh] print:aspect-[8.5/11] print:rounded-none print:shadow-none">
      <div class="relative w-full h-full flex flex-col p-4 md:p-10 print:p-4">

        <!-- header -->
        <div class="resume-header">
          <div class="flex justify-start items-center gap-6">
            <Image
              src={AvatarImg}
              width={300}
              alt="Michal Ilyayev"
              class="w-28 h-28 bg-gray-300 rounded-md shrink-0 object-cover object-center shadow-md contrast-75 brightness-150"
            />
            <div>
              <h1 class="text-2xl print:text-4xl sm:text-4xl font-[400] font-serif italic border-b border-gray-300 pb-2 mb-2">
                Michal Ilyayev
              </h1>
              <p class="text-gray-500 text-md sm:text-xl print:text-xl italic">Computer Science Student</p>
              <p class="text-gray-400 text-xs sm:text-sm italic">McMaster University</p>
            </div>
          </div>

          <div class="flex lg:justify-end print:justify-end">
            <div class="flex flex-col w-fit items-start gap-1.5 text-gray-600 text-sm">
              <a class="contact-link" href="https://github.com/michal-ilyayev" target="_blank">
                <Icon name="mdi:github" size={20} class="text-gray-500" />
                github.com/michal-ilyayev
              </a>
              <a class="contact-link" href="mailto:ilyayevm@mcmaster.ca">
                <Icon name="mdi:email" size={20} class="text-gray-500" />
                ilyayevm@mcmaster.ca
              </a>
              <a class="contact-link" href="https://michal-ilyayev.github.io" target="_blank">
                <Icon name="mdi:web" size={20} class="text-gray-500" />
                michal-ilyayev.github.io
              </a>
              <a class="contact-link" href="https://www.linkedin.com/in/michal-ilyayev/" target="_blank">
                <Icon name="mdi:linkedin" size={20} class="text-gray-500" />
                linkedin.com/in/michal-ilyayev
              </a>
            </div>
          </div>
        </div>
        <!-- header end -->

        <!-- resume body -->
        <div class="resume-body">

          <section class="summary-box">
            <h2>Summary</h2>
            <p>
              Motivated Computer Science student at McMaster University with experience in Python,
              web development, UI/UX design, and modern web technologies including Astro, React,
              Tailwind CSS, TypeScript, JavaScript, HTML, and CSS.
            </p>
            <p>
              Passionate about building creative, user-focused digital experiences that combine software
              development with visual design. Through internships, a university research role, independent
              projects, and leadership, I have developed strong skills in problem-solving, collaboration,
              and independent learning.
            </p>
          </section>

          <div>
            <h2>Experience</h2>

            <!-- Research role highlighted — most notable current position -->
            <section class="research-role">
              <div class="section-heading">
                <h3>Research Assistant, McMaster University</h3>
                <span>June 2026 – Present</span>
              </div>
              <p>
                Working within McMaster's Department of Computing and Software on human-centered
                AI-augmented visualization systems, helping users explore large datasets and extract
                insights through interactive tools.
              </p>
              <ul>
                <li>Designing and developing interactive AI-supported visualization interfaces.</li>
                <li>Working with React, React Flow, JavaScript, and modern frontend workflows.</li>
                <li>Researching human-AI interaction, information sensemaking, and data exploration.</li>
                <li>Collaborating within McMaster's Faculty of Engineering in a research environment.</li>
              </ul>
            </section>

            <section>
              <div class="section-heading">
                <h3>Independent Software Development Projects</h3>
              </div>
              <ul>
                <li>Built and designed my personal portfolio website using Astro, TypeScript, and Tailwind CSS.</li>
                <li>
                  <strong>Lockin.click</strong>: Next-generation coding assessment platform built with
                  React, Ant Design, Django/Python, and PostgreSQL.
                </li>
                <li>
                  Additional projects and games using Python, JavaScript, and PyGame available on
                  <a href="https://github.com/michal-ilyayev" target="_blank" class="text-primary hover:underline">GitHub</a>.
                </li>
              </ul>
            </section>

            <section>
              <div class="section-heading">
                <h3>Web Development Intern, NEMAL Technologies</h3>
                <span>July 2024 – Oct 2024 &amp; Apr 2026 – Present</span>
              </div>
              <p>
                NEMAL is a boutique software company building custom solutions for small businesses and
                startups. Worked closely with an experienced team to develop and maintain client-facing
                web applications.
              </p>
              <ul>
                <li>Designed and implemented responsive interfaces using Astro, React, and Tailwind CSS.</li>
                <li>Contributed to layout, accessibility, and performance improvements.</li>
                <li>Gained hands-on professional experience with modern frontend tooling.</li>
              </ul>
            </section>

            <section>
              <div class="section-heading">
                <h3>Swimming Instructor</h3>
                <span>June 2023 – August 2023</span>
              </div>
              <ul>
                <li>Taught children ages 3–12 swimming techniques and water safety practices.</li>
                <li>Adapted lessons to different skill levels while maintaining a safe and encouraging environment.</li>
              </ul>
            </section>

            <section>
              <div class="section-heading">
                <h3>Community Involvement</h3>
              </div>
              <ul>
                <li>
                  <strong>McMaster University</strong>: Active member of the Engineering Society (MES),
                  Women in Engineering (WIE), Computer Science Society, AI Society (MACIS), and DeltaHacks.
                </li>
                <li>
                  <strong>Leader and President, Shield Initiative Club</strong> (2022–2025):
                  Revived the club from 12 to 60+ members. Managed design, volunteer coordination,
                  partner outreach, fundraisers, and delivered 40+ handmade shields for children
                  undergoing cancer treatment.
                </li>
                <li>
                  <strong>High School</strong>: Student Council, Head of Visual Arts Council,
                  Programming Club, and Women in STEM.
                </li>
                <li>
                  <strong>Art Club Assistant, JRCC</strong>: Instructed children ages 5–8 in holiday art projects.
                </li>
                <li>
                  <strong>Babysitting</strong>: Supervised children ages 3–9 with organized activities and meal plans.
                </li>
              </ul>
            </section>
          </div>

          <div>
            <h2>Education</h2>

            <section class="education-card">
              <div class="section-heading school-heading">
                <div class="school-title">
                  <Image src={McMasterLogo} width={34} alt="McMaster University logo" class="school-logo" />
                  <h3>B.A.Sc. Computer Science, McMaster University</h3>
                </div>
                <span>2025 – Present</span>
              </div>
              <p>
                Studying Computer Science with interests in software development, AI, UI/UX design,
                and human-centered interactive systems.
              </p>
            </section>

            <section class="education-card">
              <div class="section-heading school-heading">
                <div class="school-title">
                  <Image src={WestmountLogo} width={42} alt="Westmount Collegiate Institute logo" class="school-logo westmount-logo" />
                  <h3>Ontario Secondary School Diploma, Westmount Collegiate Institute</h3>
                </div>
                <span>2021 – 2025</span>
              </div>
              <p>
                Graduated with an additional <em>Accelerated Visual Arts Program Diploma</em>. Completed
                university-level courses in Computer Science, Visual Arts, Advanced Functions,
                Calculus and Vectors, Physics, Chemistry, and English. Honour Roll student with
                multiple awards for academic excellence, creativity, leadership, and visual arts.
              </p>
            </section>

            <section>
              <div class="section-heading">
                <h3>Extracurriculars and Self-Study</h3>
              </div>
              <ul>
                <li>
                  <strong>Programming</strong>: Online courses and independent projects in Python,
                  HTML, CSS, JavaScript, React, Astro, and more.
                </li>
                <li>
                  <strong>Swimming</strong>: Competed since infancy, including YRAA, and earned
                  multiple medals. Certified Lifesaving and Swim Instructor.
                </li>
                <li>
                  <strong>Private Art Classes</strong>: Since 2019, developing technique and creative
                  collaboration across various visual art projects.
                </li>
                <li>
                  <strong>Piano</strong>: Private lessons since 2021 and performed twice in the school talent show.
                </li>
              </ul>
            </section>
          </div>

          <section>
            <h2>Skills</h2>
            <ul class="skill-list">
              <li><strong>Software Development</strong>: Python, JavaScript, TypeScript, HTML &amp; CSS, Astro, React, Tailwind CSS, PyGame, Git, C, PHP</li>
              <li><strong>Backend and Tools</strong>: Django/Python, PostgreSQL, Ant Design, GitHub</li>
              <li><strong>UI and Design</strong>: Figma, Adobe Photoshop, Adobe Illustrator, Canva</li>
              <li><strong>Visual Arts</strong>: Drawing, painting, digital art, 3D design, photography, mixed media</li>
              <li><strong>Soft Skills</strong>: Organized, collaborative, creative, detail-oriented, resourceful, curious, and quick to learn</li>
              <li><strong>Languages</strong>: English, Hebrew, Russian</li>
            </ul>
          </section>

          <section>
            <h2>Honors, Awards and Certifications</h2>
            <ul>
              <li><span class="award-highlight">EREA Scholarship Candidate</span>, McMaster University (2025 – Present)</li>
              <li><span class="award-highlight">Schulich Leadership Award</span> (2024 – 2025)</li>
              <li><span class="award-highlight">President's Award</span> (2024 – 2025)</li>
              <li><span class="award-highlight">Ontario Scholar Honorary Recognition</span> (2024 – 2025)</li>
              <li>Honour Roll, Grade 12, Westmount CI (2024 – 2025)</li>
              <li>Honour Roll, Grade 11, Westmount CI (2023 – 2024)</li>
              <li>Citizenship Award, Courage and Leadership (2023 – 2024)</li>
              <li>First Place, DEGA International Art Competition (2023)</li>
              <li>Honour Roll, Grade 10, Westmount CI (2022 – 2023)</li>
              <li>Academic Award, Communication Technology (2022 – 2023)</li>
              <li>Academic Award, Technological Design (2022 – 2023)</li>
              <li>Merit Award, Visual Arts (2022 – 2023)</li>
              <li>Standard First Aid with CPR "C" Certification (May 2023)</li>
              <li>Swimming and Lifesaving Instructor Certification (March 2023)</li>
              <li>Assistant Instructor Certification (February 2023)</li>
              <li>Honour Roll, Grade 9, Westmount CI (2021 – 2022)</li>
              <li>Red Cross Babysitting Certification (August 2020)</li>
            </ul>
          </section>

          <section>
            <h2>Creative Interests</h2>
            <p>
              Sketching and painting landscapes, human features, and structures; swimming; piano;
              digital art; music; badminton; fishing; kayaking; skating; hiking; and time with friends.
            </p>
          </section>

          <section>
            <h2>References</h2>
            <p>Available upon request.</p>
          </section>

        </div>
        <!-- resume body end -->

      </div>
    </div>
  </div>
</Layout>