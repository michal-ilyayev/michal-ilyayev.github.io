---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/Layout.astro';
import AvatarImg from '~/assets/img/me/3.png';
---

<Layout title="Resume">
  <div class="print:hidden absolute inset-0 bg-violet-400 bg-[size:20px_20px] opacity-20 blur-[100px]"></div>

  <button onclick="window.print();" class="btn-print" title="Print">
    <Icon name="mdi:printer" size={30} />
  </button>

  <div class="relative max-w-full min-h-screen px-0 sm:px-4 print:px-0 py-10 print:py-5">

    <!-- resume page -->
    <div class="w-full sm:max-w-[52rem] bg-white sm:rounded-md shadow-xl mx-auto
                print:w-[52rem] print:h-[100vh] print:aspect-[8.5/11] print:rounded-none print:shadow-none">
      <div class="relative w-full h-full flex flex-col p-4 md:p-10 print:p-4">

        <!-- header -->
        <div class="w-full flex flex-col lg:flex-row print:flex-row justify-between lg:items-center print:items-center gap-10">
          <div class="flex justify-start items-center gap-6">
            <div>
              <Image
                src={AvatarImg}
                width={300}
                alt="Michal Ilyayev"
                class="w-28 h-28 bg-gray-300 rounded-md shrink-0 object-cover object-center shadow-md contrast-75 brightness-150"
              />
            </div>
            <div>
              <h1
                class="text-2xl print:text-4xl sm:text-4xl font-[400] font-serif italic border-b border-gray-300 pb-2 mb-2">
                Michal Ilyayev
              </h1>
            </div>
          </div>
          <div class="flex lg:justify-end print:justify-end">
            <div class="flex flex-col w-fit items-start gap-1.5 text-gray-600 text-sm">
              <a
                class="flex items-center gap-2 hover:text-primary transition-all"
                href="tel:+16473554049"
              >
                <Icon name="mdi:phone" size={20} class="text-gray-500" />
                (647) 355-4049
              </a>
              <a
                class="flex items-center gap-2 hover:text-primary transition-all"
                href="mailto:ilyayevm@mcmaster.ca"
              >
                <Icon name="mdi:email" size={20} class="text-gray-500" />
                ilyayevm@mcmaster.ca
              </a>
              <a
                class="flex items-center gap-2 hover:text-primary transition-all"
                href="https://michal-ilyayev.github.io"
                target="_blank"
              >
                <Icon name="mdi:web" size={20} class="text-gray-500" />
                michal-ilyayev.github.io
              </a>
              <a
                class="flex items-center gap-2 hover:text-primary transition-all"
                href="https://www.linkedin.com/in/michal-ilyayev/"
                target="_blank"
              >
                <Icon name="mdi:linkedin" size={20} class="text-gray-500" />
                linkedin.com/in/michal-ilyayev
              </a>
            </div>
          </div>
        </div>
        <!-- header end -->

        <!-- resume body -->
        <div class="resume-body">
          <section>
            <h2>Summary</h2>
            <p>
              Motivated Computer Science student with experience in Python, web development, and UI/UX design. Led
              large, award-winning community projects and earned multiple recognitions including Schulich Leadership,
              EREA, and the President's Award. Demonstrated strengths in team organization, creative problem-solving,
              and learning quickly and independently.
            </p>
          </section>

          <div>
            <h2>Experience</h2>

            <section>
              <div class="section-heading">
                <h3>Independent Software Development Projects</h3>
              </div>
              <ul>
                <li>Built personal portfolio website using Astro, TypeScript, and Tailwind CSS</li>
                <li>
                  <strong>Lockin.click</strong> — Next-generation coding assessment platform. React, Ant Design,
                  Django/Python, PostgreSQL.
                </li>
                <li>
                  Additional projects and games available at:
                  <a
                    class="text-primary hover:underline"
                    href="https://github.com/michal-ilyayev"
                    target="_blank"
                  >github.com/michal-ilyayev</a>
                </li>
              </ul>
            </section>

            <section>
              <div class="section-heading">
                <h3>Web Development Intern, NEMAL Technologies</h3>
                <span>July 2024 – October 2024</span>
              </div>
              <ul>
                <li>
                  Worked with an experienced development team to develop and maintain client-facing web applications.
                </li>
                <li>
                  Assisted in UI/UX design and implemented responsive, user-friendly interfaces using Astro, React, and
                  Tailwind CSS.
                </li>
                <li>
                  Supported website updates and contributed to layout, accessibility, and performance improvements.
                </li>
              </ul>
            </section>

            <section>
              <div class="section-heading">
                <h3>Swimming Instructor</h3>
                <span>June 2023 – August 2023</span>
              </div>
              <ul>
                <li>
                  Taught children between the ages of 3 and 12 essential swimming techniques and water safety practices.
                </li>
                <li>
                  Adapted lessons to different learning levels, ensuring a safe and positive experience for all
                  students.
                </li>
              </ul>
            </section>
          </div>

          <div>
            <h2>Community Involvement</h2>

            <section>
              <div class="section-heading">
                <h3>McMaster University Community</h3>
                <span>2025 – Present</span>
              </div>
              <p>
                Active general member in: Engineering Society (MES) • Women in Engineering (WIE) • Computer Science
                Society • Artificial Intelligence Society (MACIS) • DeltaHacks
              </p>
            </section>

            <section>
              <div class="section-heading">
                <h3>Leader &amp; President of the Shield Initiative Club</h3>
                <span>2022 – 2025</span>
              </div>
              <ul>
                <li>Revived the club in 2022, started with 12 members, and by 2024, expanded to 60+ members.</li>
                <li>
                  Managed design processes, volunteer coordination, partner outreach, fundraisers, and large-scale
                  events.
                </li>
                <li>Organized and delivered over 40 wooden shields for children undergoing cancer treatment.</li>
              </ul>
            </section>

            <section>
              <div class="section-heading">
                <h3>High School Community Roles</h3>
                <span>2022 – 2025</span>
              </div>
              <p>Student Council • Head of Visual Arts Council • Programming Club • Women in STEM</p>
            </section>
          </div>

          <section>
            <h2>Skills</h2>
            <ul>
              <li>
                <strong>Software Development</strong>: Python, JavaScript, HTML, CSS, Astro, React, Tailwind CSS,
                PyGame, Git
              </li>
              <li>
                <strong>UI &amp; Digital Design</strong>: Figma, Adobe Photoshop, Adobe Illustrator, Canva
              </li>
              <li>
                <strong>Visual Arts</strong>: Proficient in drawing and painting with various mediums, Digital Art, 3D
                Design, Photography
              </li>
              <li>
                <strong>Languages</strong>: English, Hebrew, and Russian
              </li>
            </ul>
          </section>

          <section>
            <h2>Awards</h2>
            <ul>
              <li>EREA scholarship candidate (2025 – Present)</li>
              <li>Schulich Leadership Award (2024 – 2025)</li>
              <li>Ontario Scholar / Honorary (2024 – 2025)</li>
              <li>President's Award (2024 – 2025)</li>
              <li>Honour Roll, Grade 11, Westmount Collegiate Institute (2023 – 2024)</li>
              <li>Citizenship Award, Courage and Leadership (2023 – 2024)</li>
              <li>First Place in DEGA International Art Competition (2023)</li>
              <li>Honour Roll, Grade 10, Westmount Collegiate Institute (2022 – 2023)</li>
              <li>Academic Award, Communication Technology (2022 – 2023)</li>
              <li>Academic Award, Technological Design (2022 – 2023)</li>
              <li>Merit Award, Visual Arts (2022 – 2023)</li>
              <li>Standard First Aid with CPR "C" Certification (May 2023)</li>
              <li>Swimming and Life-saving Instructor Certification (March 2023)</li>
              <li>Assistant Instructor Certification (February 2023)</li>
              <li>Honour Roll, Grade 9, Westmount Collegiate Institute (2021 – 2022)</li>
              <li>Red Cross Babysitting Certification (August 2020)</li>
            </ul>
          </section>

          <div>
            <h2>Education</h2>

            <section>
              <div class="section-heading">
                <h3>B.A.Sc. Computer Science, McMaster University</h3>
                <span>2025 – Present</span>
              </div>
            </section>

            <section>
              <div class="section-heading">
                <h3>Ontario Secondary School Diploma (OSSD), Westmount Collegiate Institute</h3>
                <span>2021 – 2025</span>
              </div>
              <p>Graduated with an additional Accelerated Visual Arts Program Diploma.</p>
            </section>
          </div>

          <section>
            <h2>References</h2>
            <p>Available upon request.</p>
          </section>
        </div>
        <!-- resume body end -->

      </div>
    </div>
    <!-- resume page end -->
  </div>
</Layout>


<style lang="scss">

  .btn-print {
    @apply
    fixed top-[130px] right-0 z-[1030]
    overflow-hidden

    hidden print:hidden
    md:flex items-center justify-center text-center
    text-primary bg-white
    py-4
    pl-4
    pr-2
    rounded-l-2xl

    no-underline
    shadow-sm
    drop-shadow-sm
    border
    border-primary
    border-r-0
    cursor-pointer
    transition-all
    hover:bg-primary-light
    hover:text-white;
  ;
  }

  .resume-body {
    h2 {
      @apply mt-10 text-lg font-serif font-bold border-b border-gray-300 mb-4;

    }

    section {
      break-inside: avoid;
    }

    .section-heading {
      @apply flex justify-between items-center flex-wrap gap-2 w-full mt-5 mb-2;

      span {
        @apply text-gray-700 text-sm italic;
      }
    }

    h3 {
      @apply font-semibold italic text-gray-800;
    }

    ul {
      @apply list-disc list-outside ml-4;
    }

    li,
    p {
      @apply text-gray-600 mb-2 mr-2 text-sm;
    }

    strong {
      @apply font-semibold text-gray-800;
    }
  }

</style>
