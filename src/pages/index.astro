---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Layout from "~/layouts/Layout.astro";
import MeImg from "~/assets/img/me/1.jpeg";
---

<Layout>
  <main class="home-page">
    <div class="bg-grid"></div>

    <!-- HERO -->
    <section class="hero-grid">
      <!-- LEFT: photo -->
      <aside class="hero-card">
        <div class="portrait-frame">
          <Image
            src={MeImg}
            height={900}
            alt="Michal Ilyayev"
            class="portrait-img"
          />
        </div>
      </aside>

      <!-- RIGHT: content -->
      <section class="hero-content">
        <h1>MICHAL <span>Ilyayev</span></h1>
        <p class="tagline">Software Developer</p>

        <div class="social-row">
          <a
            href="https://github.com/michal-ilyayev"
            target="_blank"
            aria-label="GitHub"
            class="social-github"
          >
            <Icon name="mdi:github" size={22} />
          </a>
          <a
            href="https://www.linkedin.com/in/michal-ilyayev/"
            target="_blank"
            aria-label="LinkedIn"
            class="social-linkedin"
          >
            <Icon name="mdi:linkedin" size={22} />
          </a>
          <a href="/contact/" aria-label="Contact" class="social-email">
            <Icon name="mdi:email-outline" size={22} />
          </a>
        </div>

        <div class="divider"></div>
        <div class="intro-box">
          <p>
            I'm a Computer Science student at McMaster University with a passion
            for software development, innovation, creativity, and thoughtful digital
            experiences.
          </p>

          <p>
            My interest in tech began when my dad first introduced me to coding.
            Since then, I've been drawn to combining programming, design, and
            creativity to bring ideas to life, shaped further by my background
            in visual arts and leadership as a <em>Schulich Leader</em>.
          </p>
        </div>

        <div class="button-row">
          <a href="/portfolio/software/" class="main-btn">
            Coding projects <Icon name="mdi:arrow-right" size={18} />
          </a>
          <a href="/resume/" class="secondary-btn">
            Resume <Icon name="mdi:file-document-outline" size={18} />
          </a>
        </div>
      </section>
    </section>

    <!-- MOBILE ONLY: bio + buttons shown below photo -->
    <div class="mobile-bio">
      <div class="divider"></div>
      <p>
        I'm a Computer Science student at McMaster University as well as a <em>Schulich Leader</em> with a passion for software development,innovation, creativity, and thoughtful
        digital experiences.
      </p>

      <p>
        My interest in tech began when my dad first introduced me to coding.
        Since then, I've been drawn to combining programming, design, and
        creativity to bring ideas to life.
      </p>
      <div class="button-row">
        <a href="/portfolio/software/" class="main-btn">
          Coding projects <Icon name="mdi:arrow-right" size={18} />
        </a>
        <a href="/resume/" class="secondary-btn">
          Resume <Icon name="mdi:file-document-outline" size={18} />
        </a>
      </div>
    </div>

    <!-- PAST PROJECTS -->
    <section class="project-section">
      <p class="section-label">Past Highlights</p>
      <div class="project-grid">
        <a
          href="/portfolio/shield-initiative/"
          class="project-card project-card--shield"
        >
          <div class="card-icon card-icon--shield">
            <Icon name="mdi:shield-outline" size={26} />
          </div>
          <h3>Shield Initiative</h3>
          <p>
            Revived and led a student-led initiative creating custom IV pole
            platforms (shields) for pediatric oncology patients, contributing to
            the production of 40+ shields through collaboration with community
            partners and volunteers.
          </p>
          <span class="card-cta"
            >View project <Icon name="mdi:arrow-right" size={14} /></span
          >
        </a>

        <a
          href="/portfolio/visual-arts/"
          class="project-card project-card--art"
        >
          <div class="card-icon card-icon--art">
            <Icon name="mdi:palette-outline" size={26} />
          </div>
          <h3>Visual Arts</h3>
          <p>
            Completed Westmount CI’s specialized Visual Arts Program, building a
            strong foundation in visual storytelling, design, and creative
            thinking. This portfolio includes a selection of some of my
            favourite pieces and projects.
          </p>
          <span class="card-cta"
            >View gallery <Icon name="mdi:arrow-right" size={14} /></span
          >
        </a>
      </div>
    </section>
  </main>
</Layout>
