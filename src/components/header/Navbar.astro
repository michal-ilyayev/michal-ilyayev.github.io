---
import { Icon } from "astro-icon/components";
import NavLink from "../NavLink.astro";

// used to highlight the dropdown trigger when on a past-highlights page
const pathname = Astro.url.pathname;
const isPastHighlights =
  pathname.startsWith("/portfolio/shield-initiative") ||
  pathname.startsWith("/portfolio/visual-arts");
---

<div class="navbar">
  <div class="flex justify-center lg:hidden">
    <button id="nav-toggle-btn" aria-label="Toggle Menu">
      <Icon id="nav-open" name="mdi:menu" size={35} class="text-gray-800" />
      <Icon
        id="nav-close"
        name="mdi:close"
        size={35}
        class="text-gray-800 hidden"
      />
    </button>
  </div>
  <nav class="hidden">
    <ul>
      <li>
        <NavLink href="/">Home</NavLink>
      </li>
      <li>
        <NavLink href="/resume/">Resume</NavLink>
      </li>
      <li>
        <NavLink href="/portfolio/software/">Coding Projects</NavLink>
      </li>

      <!-- Past Highlights dropdown -->
      <!-- trigger gets .active class when on a past-highlights page -->
      <li class="dropdown-wrap">
        <button
          class={`dropdown-trigger${isPastHighlights ? " active" : ""}`}
          aria-expanded="false"
        >
          Past Highlights
          <Icon name="mdi:chevron-down" size={15} class="dropdown-chevron" />
        </button>
        <ul class="dropdown-menu">
          <li>
            <a
              href="/portfolio/shield-initiative/"
              class={`dropdown-item${pathname.startsWith("/portfolio/shield-initiative") ? " active" : ""}`}
            >
              <Icon name="mdi:shield-outline" size={15} class="icon-shield" />
              Shield Initiative
            </a>
          </li>
          <li>
            <a
              href="/portfolio/visual-arts/"
              class={`dropdown-item${pathname.startsWith("/portfolio/visual-arts") ? " active" : ""}`}
            >
              <Icon name="mdi:palette-outline" size={15} class="icon-art" />
              Visual Arts
            </a>
          </li>
        </ul>
      </li>

      <li>
        <NavLink href="/contact/">Contact</NavLink>
      </li>
    </ul>
  </nav>
</div>

<script is:inline data-astro-rerun>
  // Guard — exits early if elements aren't in the DOM (prevents errors on navigation)
  const navToggleBtn = document.getElementById("nav-toggle-btn");
  const navEl = document.querySelector(".navbar nav");
  const navOpen = document.getElementById("nav-open");
  const navClose = document.getElementById("nav-close");
  const trigger = document.querySelector(".dropdown-trigger");
  const menu = document.querySelector(".dropdown-menu");
  const chevron = document.querySelector(".dropdown-chevron");

  if (!navToggleBtn || !navEl || !trigger || !menu) {
    // elements not found — skip setup to avoid click errors on other pages
  } else {
    // ── hamburger ────────────────────────────────────────────────────────────

    function closeDropdown() {
      menu.classList.remove("open");
      chevron.classList.remove("rotated");
      trigger.setAttribute("aria-expanded", "false");
    }

    function toggleMenu(close) {
      close = close === undefined ? !navEl.classList.contains("hidden") : close;
      navEl.classList.toggle("hidden", close);
      navOpen.classList.toggle("hidden", !close);
      navClose.classList.toggle("hidden", close);
      if (close) closeDropdown();
    }

    navToggleBtn.addEventListener("click", () => toggleMenu(undefined));

    document.querySelectorAll(".navbar nav a").forEach((link) => {
      link.addEventListener("click", () => toggleMenu(true));
    });

    document.addEventListener("click", (event) => {
      if (
        !event.target.closest(".navbar") &&
        !event.target.closest(".navbar nav")
      ) {
        toggleMenu(true);
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") toggleMenu(true);
    });

    // ── dropdown ─────────────────────────────────────────────────────────────

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = menu.classList.toggle("open");
      chevron.classList.toggle("rotated", isOpen);
      trigger.setAttribute("aria-expanded", String(isOpen));
    });

    document.addEventListener("click", (e) => {
      if (!e.target.closest(".dropdown-wrap")) closeDropdown();
    });
  }
</script>

<style lang="scss" is:global>
  .navbar {
    #nav-toggle-btn {
      @apply transform outline-none cursor-pointer
      border-none bg-transparent
      transition ease-in-out delay-75;
    }

    nav {
      @apply lg:flex transition ease-in-out delay-150;

      > ul {
        @apply absolute top-[80px] pb-24 left-0
        flex flex-col justify-center
        bg-white w-full p-4 gap-2 text-center
        h-[calc(100vh-80px)]

        lg:p-0 lg:gap-1 lg:h-auto
        lg:relative lg:top-0
        lg:flex-row lg:bg-transparent lg:w-auto
        xl:gap-5;

        li a {
          @apply flex flex-row items-center justify-around
          text-gray-600 text-sm h-full
          rounded-md
          hover:text-primary hover:bg-violet-50
          border-b-2 border-transparent
          px-1 py-4 w-full
          transition ease-in-out delay-75

          lg:py-3 lg:px-2 lg:text-sm xl:px-4;

          &.active {
            @apply hover:bg-transparent text-primary bg-violet-100
            lg:bg-transparent lg:border-b-2 lg:border-primary lg:rounded-none;
          }
        }
      }
    }
  }

  // ── Past Highlights dropdown ──────────────────────────────────────────────

  .dropdown-wrap {
    position: relative;
  }

  // Trigger — matches nav link style exactly
  // Gets .active when on a past-highlights page (set in frontmatter above)
  .dropdown-trigger {
    @apply flex flex-row items-center justify-around
    text-gray-600 text-sm
    rounded-md
    hover:text-primary hover:bg-violet-50
    border-b-2 border-transparent
    px-1 py-4 w-full
    transition ease-in-out delay-75
    bg-transparent border-none cursor-pointer gap-1
    lg:py-3 lg:px-2 xl:px-4;

    // active state — same as NavLink .active on desktop
    &.active {
      @apply text-primary;

      @media (min-width: 1024px) {
        @apply bg-transparent border-b-2 border-primary rounded-none;
      }

      @media (max-width: 1023px) {
        @apply bg-violet-100;
      }
    }
  }

  .dropdown-chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
    &.rotated {
      transform: rotate(180deg);
    }
  }

  // Hidden by default — .open shows it
  // Mobile: expands inline | Desktop: floats as a card
  .dropdown-menu {
    display: none;
    flex-direction: column;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 2px;

    &.open {
      display: flex;
    }

    @media (min-width: 1024px) {
      position: absolute;
      top: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: #fff;
      border: 1px solid rgba(112, 101, 249, 0.12);
      border-radius: 10px;
      padding: 5px;
      min-width: 210px; // wide enough for "Shield Initiative" on laptop
      box-shadow: 0 6px 20px rgba(112, 101, 249, 0.1);
      z-index: 50;
    }
  }

  // Dropdown items
  .dropdown-item {
    @apply flex flex-row items-center justify-around
    text-gray-600 text-sm
    rounded-md
    hover:text-primary hover:bg-violet-50
    px-3 py-3 w-full
    transition ease-in-out delay-75
    no-underline gap-2;

    // active — purple bg like the rest of the nav
    &.active {
      @apply text-primary bg-violet-100;
    }

    @media (min-width: 1024px) {
      justify-content: flex-start;
    }
  }

  // Coloured icons inside the dropdown
  .icon-shield {
    color: #5ab4f0;
  } // blue — matches the shield card
  .icon-art {
    color: #f06ab7;
  } // pink — matches the visual arts card

  // keep icon colours even on active/hover
  .dropdown-item:hover .icon-shield,
  .dropdown-item.active .icon-shield {
    color: #5ab4f0;
  }
  .dropdown-item:hover .icon-art,
  .dropdown-item.active .icon-art {
    color: #f06ab7;
  }
</style>
