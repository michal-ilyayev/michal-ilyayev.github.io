---
import { Icon } from "astro-icon/components";
import NavLink from "../NavLink.astro";

// highlights "Past Highlights" trigger when on either sub-page
const pathname = Astro.url.pathname;
const isPastHighlights =
  pathname.startsWith("/portfolio/shield-initiative") ||
  pathname.startsWith("/portfolio/visual-arts");
---

<div class="navbar">
  <div class="flex justify-center lg:hidden">
    <button id="nav-toggle-btn" aria-label="Toggle Menu">
      <Icon id="nav-open" name="mdi:menu" size={35} class="text-gray-800" />
      <Icon id="nav-close" name="mdi:close" size={35} class="text-gray-800 hidden" />
    </button>
  </div>
  <nav class="hidden">
    <ul>
      <li><NavLink href="/">Home</NavLink></li>
      <li><NavLink href="/resume/">Resume</NavLink></li>
      <li><NavLink href="/portfolio/software/">Coding Projects</NavLink></li>

      <!-- Past Highlights dropdown — add more items inside .dropdown-menu as needed -->
      <li class="dropdown-wrap">
        <button
          class={`dropdown-trigger${isPastHighlights ? " active" : ""}`}
          aria-expanded="false"
        >
          Past Highlights
          <Icon name="mdi:chevron-down" size={15} class="dropdown-chevron" />
        </button>
        <ul class="dropdown-menu">
          <li>
            <a
              href="/portfolio/shield-initiative/"
              class={`dropdown-item${pathname.startsWith("/portfolio/shield-initiative") ? " active" : ""}`}
            >
              <Icon name="mdi:shield-outline" size={15} class="icon-shield" />
              Shield Initiative
            </a>
          </li>
          <li>
            <a
              href="/portfolio/visual-arts/"
              class={`dropdown-item${pathname.startsWith("/portfolio/visual-arts") ? " active" : ""}`}
            >
              <Icon name="mdi:palette-outline" size={15} class="icon-art" />
              Visual Arts
            </a>
          </li>
        </ul>
      </li>

      <li><NavLink href="/contact/">Contact</NavLink></li>
    </ul>
  </nav>
</div>

<script is:inline>
  function initNavbar() {
    const navToggleBtn = document.getElementById("nav-toggle-btn");
    const navEl        = document.querySelector(".navbar nav");
    const navOpen      = document.getElementById("nav-open");
    const navClose     = document.getElementById("nav-close");
    const trigger      = document.querySelector(".dropdown-trigger");
    const menu         = document.querySelector(".dropdown-menu");
    const chevron      = document.querySelector(".dropdown-chevron");

    // bail out if elements aren't in the DOM — prevents errors on other pages
    if (!navToggleBtn || !navEl || !trigger || !menu) return;

    // AbortController cleans up all listeners on each View Transition navigation
    window.__navbarAbort?.abort();
    const { signal } = (window.__navbarAbort = new AbortController());

    function closeDropdown() {
      menu.classList.remove("open");
      chevron?.classList.remove("rotated");
      trigger.setAttribute("aria-expanded", "false");
    }

    function toggleMenu(close) {
      close = close === undefined ? !navEl.classList.contains("hidden") : close;
      navEl.classList.toggle("hidden", close);
      navOpen?.classList.toggle("hidden", !close);
      navClose?.classList.toggle("hidden", close);
      if (close) closeDropdown();
    }

    // reset to closed state on every navigation
    navEl.classList.add("hidden");
    navOpen?.classList.remove("hidden");
    navClose?.classList.add("hidden");
    closeDropdown();

    // hamburger toggle
    navToggleBtn.addEventListener("click", () => toggleMenu(undefined), { signal });

    // close menu when any link is clicked
    navEl.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => toggleMenu(true), { signal });
    });

    // close on outside click or Escape
    document.addEventListener("click", (e) => {
      if (!e.target.closest(".navbar")) toggleMenu(true);
    }, { signal });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") { toggleMenu(true); closeDropdown(); }
    }, { signal });

    // dropdown toggle — stopPropagation so the outside-click handler doesn't fire
    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = menu.classList.toggle("open");
      chevron?.classList.toggle("rotated", isOpen);
      trigger.setAttribute("aria-expanded", String(isOpen));
    }, { signal });

    document.addEventListener("click", (e) => {
      if (!e.target.closest(".dropdown-wrap")) closeDropdown();
    }, { signal });
  }

  document.addEventListener("astro:page-load", initNavbar);
</script>

<style lang="scss" is:global>

  .navbar {
    #nav-toggle-btn {
      @apply outline-none cursor-pointer border-none bg-transparent transition ease-in-out delay-75;
    }

    nav {
      @apply lg:flex transition ease-in-out delay-150;

      > ul {
        @apply
        absolute top-[80px] left-0 pb-24
        flex flex-col justify-center text-center
        bg-white w-full p-4 gap-2
        h-[calc(100vh-80px)]
        lg:static lg:h-auto lg:p-0 lg:gap-1
        lg:flex-row lg:bg-transparent lg:w-auto
        xl:gap-5;

        // top-level links only — dropdown items are styled separately below
        > li > a {
          @apply
          flex flex-row items-center justify-around h-full
          text-gray-600 text-sm rounded-md
          hover:text-primary hover:bg-violet-50
          border-b-2 border-transparent
          px-1 py-4 w-full
          transition ease-in-out delay-75
          lg:py-3 lg:px-2 xl:px-4;

          &.active {
            @apply text-primary bg-violet-100 hover:bg-transparent
            lg:bg-transparent lg:border-b-primary lg:rounded-none;
          }
        }
      }
    }
  }

  // ── Past Highlights dropdown ──────────────────────────────────────────────

  .dropdown-wrap { position: relative; }

  // Trigger looks like a nav link but is a <button>
  // border-bottom written in plain CSS — Tailwind's border-b shorthand
  // conflicts with button's default borders and loses the active underline
  .dropdown-trigger {
    @apply
    flex flex-row items-center justify-center gap-1
    text-gray-600 text-sm rounded-md
    hover:text-primary hover:bg-violet-50
    px-1 py-4 w-full
    transition ease-in-out delay-75
    bg-transparent cursor-pointer
    lg:py-3 lg:px-2 xl:px-4;

    border-top: none;
    border-left: none;
    border-right: none;
    border-bottom: 2px solid transparent;

    // active: underline on desktop, fill on mobile — matches other nav links
    // !important needed because Tailwind utility classes win on specificity
    &.active {
      color: #7065f9;

      @media (min-width: 1024px) {
        background: transparent !important;
        border-bottom: 2px solid #7065f9 !important;
        border-radius: 0 !important;
      }

      @media (max-width: 1023px) {
        background: #ede9fe;
      }
    }
  }

  // rotates when dropdown opens
  .dropdown-chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
    &.rotated { transform: rotate(180deg); }
  }

  // mobile: expands inline | desktop: floats as a card below trigger
  .dropdown-menu {
    display: none;
    flex-direction: column;
    list-style: none;
    padding: 0; margin: 0; gap: 2px;

    &.open { display: flex; }

    @media (min-width: 1024px) {
      position: absolute;
      top: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      min-width: 210px; // keeps "Shield Initiative" on one line
      background: #fff;
      border: 1px solid rgba(112, 101, 249, 0.12);
      border-radius: 10px;
      padding: 5px;
      box-shadow: 0 6px 20px rgba(112, 101, 249, 0.1);
      z-index: 50;
    }
  }

  // fill only — no underline on dropdown items
  .dropdown-item {
    @apply
    flex flex-row items-center gap-2
    text-gray-600 text-sm rounded-md
    hover:text-primary hover:bg-violet-50
    px-3 py-3 w-full
    transition ease-in-out delay-75 no-underline;

    border-bottom: none;
    justify-content: center;

    &.active { @apply text-primary bg-violet-100; }

    svg { flex-shrink: 0; }

    @media (min-width: 1024px) { justify-content: flex-start; }
  }

  // icon colours — match the project cards in _home.scss
  // to change: update the same colour in both places
  .icon-shield { color: #5ab4f0; }
  .icon-art    { color: #f06ab7; }

  .dropdown-item:hover .icon-shield,
  .dropdown-item.active .icon-shield { color: #5ab4f0; }
  .dropdown-item:hover .icon-art,
  .dropdown-item.active .icon-art    { color: #f06ab7; }

</style>